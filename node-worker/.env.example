# Flight Path Worker — environment variables
#
# Copy this file to ".env" and fill in real values. (".env" is gitignored.)
# Start the local database first (from the repo root): docker compose up -d

# Notion Configuration
# API key: https://www.notion.so/profile/integrations (create an "internal integration")
# Root page id: the "Flight Path Program" wiki id (see SETUP_GUIDE for how to share it
# to the integration and copy its id).
NOTION_API_KEY=your_notion_integration_secret_here
NOTION_ROOT_PAGE_ID=your_notion_root_page_id_here

# Local Postgres (must match the repo-root .env). Port 5433 on this Mac.
DATABASE_URL=postgres://flightpath:flightpath_local_dev_pw@localhost:5433/flightpath

# Worker Configuration
WORKER_MODE=manual              # Options: schedule, manual, cron
CRON_EXPRESSION=*/30 * * * *    # Run every 30 minutes (schedule/cron modes)
MAX_DEPTH=5                     # Maximum recursion depth for crawling
CONCURRENT_REQUESTS=3           # Concurrent Notion API requests
DELAY_BETWEEN_REQUESTS=1000     # Delay between requests in ms

# Logging
LOG_LEVEL=info                  # Options: debug, info, warn, error
