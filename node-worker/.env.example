# Flight Path Worker Environment Variables

# Notion Configuration
NOTION_API_KEY=your_notion_api_key_here
NOTION_ROOT_PAGE_ID=your_notion_root_page_id_here

# Supabase Configuration (for saving crawled data)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Worker Configuration
WORKER_MODE=schedule              # Options: schedule, manual, cron
CRON_EXPRESSION=*/30 * * * *      # Run every 30 minutes
MAX_DEPTH=5                       # Maximum recursion depth for crawling
CONCURRENT_REQUESTS=3              # Concurrent Notion API requests
DELAY_BETWEEN_REQUESTS=1000       # Delay between requests in ms

# Logging
LOG_LEVEL=info                    # Options: debug, info, warn, error
