# Flight Path — database credentials (LOCAL only)
#
# Copy this file to ".env" and fill in real values, then run:
#   docker compose up -d
#
# The .env file is gitignored and must NEVER be committed.
# These values are read automatically by docker-compose.yml.

# Port exposed ON THE HOST (your Mac). 5433 by default because 5432 is in use.
POSTGRES_PORT=5433

# Database name + the user the app will connect as.
POSTGRES_DB=flightpath
POSTGRES_USER=flightpath

# Set a real password. Use something long and random.
POSTGRES_PASSWORD=change_me_to_a_long_random_string

# ---- Used by the app/worker later (not needed to start the DB) ----
# The connection string the Next.js app and worker will use to talk to Postgres.
# Match the values above. PORT must equal POSTGRES_PORT.
DATABASE_URL=postgres://flightpath:change_me_to_a_long_random_string@localhost:5433/flightpath
