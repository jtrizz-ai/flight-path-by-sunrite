# ─────────────────────────────────────────────────────────────────────────
# Flight Path — Web (Next.js) environment variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All variables are validated at boot — missing required vars throw a clear
# error naming what's missing.

# ── Database (Postgres on the trashcan over Tailscale) ───────────────────
# Host: 100.117.75.7, port 5432, DB: flightpath, user: flightpath_user.
# Password is in 1Password as "Flight Path DB user (trashcan)".
# sslmode=disable is safe — Tailscale already encrypts the wire (PG-level
# SSL is off at the server).
DATABASE_URL=postgres://flightpath_user:REPLACE_ME@100.117.75.7:5432/flightpath?sslmode=disable

# ── Auth.js (NextAuth v5) ────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
AUTH_SECRET=replace_with_random_32_byte_string
AUTH_URL=http://localhost:3101

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# ── Notion (for node-worker crawl; web reads from Postgres cache) ────────
# The Flight Path Program wiki root page ID (32-char hex from the Notion URL).
# Share the integration with the wiki in Notion Settings → Connections.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ROOT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local LLM (OpenAI-compatible endpoint) ───────────────────────────────
# Default points at Jonathan's Mac Studio over Tailscale. These seed the
# admin_settings.llm_config row on first boot; afterwards they are editable
# from the /admin portal and stored in the database.
LLM_BASE_URL=http://100.101.18.67:1234/v1
LLM_MODEL=qwen3.5-122b-a10b
LLM_API_KEY=not-needed-for-local

# ── iOS app API token ────────────────────────────────────────────────────
# Extra check sent as header `x-app-token` by the iOS app. Any long random
# string; set the same value in the iOS AppConfig.
APP_API_TOKEN=long_random_string_for_ios_app

# ── Admin / sync reindex token ───────────────────────────────────────────
# Sent as header `x-admin-token` for /api/sync and /api/chat/reindex.
ADMIN_TOKEN=long_random_string_for_admin_ops

# ── Login gate policy ────────────────────────────────────────────────────
# Seed only — stored in the allowed_domains table on first boot, then
# editable from /admin. Comma-separated list of allowed email domains.
DEFAULT_ALLOWED_DOMAIN=sunritesolarllc.com
# If "true", an email must also exist in the invites table to sign in.
INVITE_REQUIRED=true

# ── Seed admin email ─────────────────────────────────────────────────────
# Inserted into app_users with role=admin on first boot.
ADMIN_SEED_EMAIL=jrizzo@sunritesolarllc.com

# ── Notion sync (admin "Sync Now" button) ─────────────────────────────────
# Absolute path to the node-worker folder. /api/sync spawns its `dist/index.js`
# in manual mode to run a one-off crawl. Default: ../node-worker (relative to
# this web folder). Run `npm run build` inside node-worker first.
# NODE_WORKER_DIR=/Users/you/flight-path-by-sunrite/node-worker
